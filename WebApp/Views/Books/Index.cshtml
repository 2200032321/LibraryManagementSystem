@model List<WebApp.Models.BookViewModel>

@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Books";
    var role = Context.Session.GetString("Role");
}

<h2 class="mb-4">📚 Books Management</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">

    @if (role == "Admin" || role == "Librarian")
    {
        <a asp-action="Create" class="btn btn-primary">
            + Add Book
        </a>
    }
    else
    {
        <div></div>
    }

    <input type="text"
           id="searchBox"
           class="form-control w-25"
           placeholder="Search books..." />

</div>

<table class="table table-hover table-bordered shadow-sm"
       id="booksTable">

    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Book</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Total</th>
            <th>Available</th>
            <th>Status</th>
            <th width="350">Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var book in Model)
        {
            <tr>

                <td>@book.Id</td>

                <td>

                    @if (!string.IsNullOrWhiteSpace(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl"
                             width="40"
                             height="55"
                             class="me-2 rounded" />
                    }

                    <strong>@book.Title</strong>

                    @if (book.IsEBook)
                    {
                        <span class="badge bg-info ms-1">
                            E-Book
                        </span>
                    }

                </td>

                <td>@book.Author</td>

                <td>@book.ISBN</td>

                <td>@book.TotalCopies</td>

                <td>
                    <span class="badge bg-secondary">
                        @book.AvailableCopies
                    </span>
                </td>

                <td>

                    @if (book.AvailableCopies > 0)
                    {
                        <span class="badge bg-success">
                            Available
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Out of Stock
                        </span>
                    }

                </td>

                <td class="text-nowrap">

                    <!-- VIEW -->
                    <a asp-action="Details"
                       asp-route-id="@book.Id"
                       class="btn btn-info btn-sm">
                        View
                    </a>

                    <!-- EBOOK READ -->
                    @if (book.IsEBook &&
                   !string.IsNullOrWhiteSpace(book.EBookFileUrl))
                    {
                        <a href="@book.EBookFileUrl"
                           target="_blank"
                           class="btn btn-success btn-sm">
                            Read
                        </a>
                    }

                    <!-- STUDENT RESERVE -->
                    @if (role == "Student" &&
                   book.AvailableCopies == 0)
                    {
                        <form asp-controller="Reservations"
                              asp-action="Reserve"
                              method="post"
                              class="d-inline">

                            <input type="hidden"
                                   name="bookId"
                                   value="@book.Id" />

                            <button type="submit"
                                    class="btn btn-primary btn-sm">
                                Reserve
                            </button>

                        </form>
                    }

                    <!-- LIBRARIAN + ADMIN -->
                    @if (role == "Admin" ||
                   role == "Librarian")
                    {
                        <a asp-action="Edit"
                           asp-route-id="@book.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>
                    }

                    <!-- ADMIN ONLY -->
                    @if (role == "Admin")
                    {
                        <form asp-action="Delete"
                              asp-route-id="@book.Id"
                              method="post"
                              class="d-inline"
                              onsubmit="return confirm('Are you sure you want to delete this book?');">

                            <button type="submit"
                                    class="btn btn-danger btn-sm">
                                Delete
                            </button>

                        </form>
                    }

                </td>

            </tr>
        }

    </tbody>

</table>

<script>
    document
        .getElementById("searchBox")
        .addEventListener("keyup", function () {

            let value =
                this.value.toLowerCase().trim();

            let rows =
                document.querySelectorAll(
                    "#booksTable tbody tr");

            rows.forEach(row => {

                let text =
                    row.innerText.toLowerCase();

                row.style.display =
                    text.includes(value)
                        ? ""
                        : "none";
            });
        });
</script>
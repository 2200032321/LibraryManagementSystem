@model WebApp.Models.ReportViewModel

@{
    ViewData["Title"] = "Reports";
}

<h2 class="mb-4">
    📊 Library Reports
</h2>

<div class="row">

    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5>Total Books</h5>
                <h2>@Model.TotalBooks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5>Total Users</h5>
                <h2>@Model.TotalUsers</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-warning">
            <div class="card-body">
                <h5>Total Transactions</h5>
                <h2>@Model.TotalTransactions</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h5>Overdue Books</h5>
                <h2>@Model.OverdueBooks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5>Reservations</h5>
                <h2>@Model.TotalReservations</h2>
            </div>
        </div>
    </div>

</div>
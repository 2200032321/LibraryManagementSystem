@model WebApp.Models.DashboardViewModel

@{
    var role = Context.Session.GetString("Role");
    ViewData["Title"] = role + " Dashboard";
}

<h2 class="mb-4">📊 @role Dashboard</h2>

<div class="row text-center">

    <div class="col-md-3 mb-3">
        <div class="card bg-primary text-white shadow p-3">
            <h5>📚 Books</h5>
            <h2>@Model.TotalBooks</h2>
        </div>
    </div>

    @if (role == "Admin")
    {
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white shadow p-3">
                <h5>👥 Users</h5>
                <h2>@Model.TotalUsers</h2>
            </div>
        </div>
    }

    <div class="col-md-3 mb-3">
        <div class="card bg-warning text-dark shadow p-3">
            <h5>🔄 Transactions</h5>
            <h2>@Model.TotalTransactions</h2>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-danger text-white shadow p-3">
            <h5>⚠ Overdue</h5>
            <h2>@Model.OverdueBooks</h2>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-info text-white shadow p-3">
            <h5>📌 Reservations</h5>
            <h2>@Model.TotalReservations</h2>
        </div>
    </div>

</div>

<hr />

<div class="card shadow p-3">
    <canvas id="dashboardChart" height="100"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    let labels = [];
    let values = [];
    let colors = [];

    labels.push("Books");
    values.push(@Model.TotalBooks);
    colors.push("#0d6efd");

    @if (role == "Admin")
    {
        <text>
            labels.push("Users");
            values.push(@Model.TotalUsers);
            colors.push("#198754");
        </text>
    }

    labels.push("Transactions");
    values.push(@Model.TotalTransactions);
    colors.push("#ffc107");

    labels.push("Overdue");
    values.push(@Model.OverdueBooks);
    colors.push("#dc3545");

    labels.push("Reservations");
    values.push(@Model.TotalReservations);
    colors.push("#0dcaf0");

    new Chart(document.getElementById("dashboardChart"), {
        type: "bar",
        data: {
            labels: labels,
            datasets: [{
                label: "Library Statistics",
                data: values,
                backgroundColor: colors
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                }
            }
        }
    });

</script>